# Codex Exec Policy Rules
# Language: Starlark (Python-like)
# See: https://developers.openai.com/codex/config-reference#rules

# --- Package Manager ---
prefix_rule(
    pattern = ["bun", ["install", "add", "remove", "update"]],
    decision = "prompt",
    justification = "Package changes affect lockfile and dependencies.",
)
prefix_rule(
    pattern = ["pnpm", ["install", "add", "remove", "update"]],
    decision = "prompt",
    justification = "Package changes affect lockfile and dependencies.",
)
prefix_rule(
    pattern = ["npm", ["install", "uninstall", "update"]],
    decision = "prompt",
    justification = "Package changes affect lockfile and dependencies.",
)

# --- Lint & Type Check ---
prefix_rule(
    pattern = ["npx", "eslint"],
    decision = "allow",
    justification = "ESLint for code quality checks.",
)
prefix_rule(
    pattern = ["npx", "prettier"],
    decision = "allow",
    justification = "Prettier for code formatting.",
)
prefix_rule(
    pattern = ["npx", "vue-tsc"],
    decision = "allow",
    justification = "TypeScript type checking.",
)
prefix_rule(
    pattern = ["npx", "tsc"],
    decision = "allow",
    justification = "TypeScript type checking.",
)

# --- Git ---
prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show", "branch", "remote"]],
    decision = "allow",
    justification = "Read-only git operations.",
)
prefix_rule(
    pattern = ["git", ["add", "checkout", "switch", "restore"]],
    decision = "allow",
    justification = "Standard git working tree operations.",
)
prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Committing requires review of message and changes.",
)
prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing to remote requires confirmation.",
)
prefix_rule(
    pattern = ["git", ["reset", "rebase", "merge"]],
    decision = "prompt",
    justification = "History-modifying git operations require confirmation.",
)
prefix_rule(
    pattern = ["git", "push", ["--force", "-f", "--force-with-lease", "--force-if-includes"]],
    decision = "forbidden",
    justification = "Force push is dangerous.",
)

# --- Build ---
prefix_rule(
    pattern = [["pnpm", "npm"], "run", ["build", "dev", "preview"]],
    decision = "allow",
    justification = "Build and dev server commands.",
)
prefix_rule(
    pattern = [["pnpm", "npm"], "run", ["test", "test:unit", "test:e2e"]],
    decision = "allow",
    justification = "Test execution commands.",
)
prefix_rule(
    pattern = [["pnpm", "npm"], "run", ["lint", "typecheck", "format"]],
    decision = "allow",
    justification = "Code quality commands.",
)

# --- Dangerous Commands ---
prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Destructive recursive delete of root.",
)
prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "prompt",
    justification = "Recursive delete requires confirmation.",
)
