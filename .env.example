# =============================================================================
# 飞加环境变量模板
# 用法：
# 1. 复制为根目录 `.env`
# 2. 本地开发可直接使用默认值
# 3. 生产部署请替换数据库、Redis、对象存储与短信服务的真实配置
# 4. 如果 URL 中密码包含 `#`、`!`、`@` 等特殊字符，请做 URL 编码
# 5. 环境区分：创建 `.env.production` 写入 `NODE_ENV=production` 及生产覆盖值；
#    服务启动时自动加载 `.env`（公共）+ `.env.{NODE_ENV}`（环境专属，覆盖公共）
# =============================================================================

# -----------------------------------------------------------------------------
# 运行环境
# NODE_ENV：
# - 不设置或 development：开发模式（CORS 自动放行私网、Swagger 默认开启等）
# - production：生产模式（CORS 严格按配置、Swagger 默认关闭等）
# - test：测试模式（日志静默、mock 短信等）
# 建议：开发时通过命令行 `NODE_ENV=development` 或写在 .env；
#       生产时在 .env.production 中设置 NODE_ENV=production。
# -----------------------------------------------------------------------------
# NODE_ENV=production

# -----------------------------------------------------------------------------
# 数据库
# 数据库连接串，默认对齐 docker/database 中的 PostgreSQL 配置
# 本地默认库名：feijia
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://feijia_dev:F3j%21a_D3v_2026%23pg@localhost:5432/feijia

# -----------------------------------------------------------------------------
# 服务端与前端端口
# SERVER_PORT：后端 API 监听端口
# WEB_DEV_PORT：用户端 Vite 开发端口
# ADMIN_DEV_PORT：管理端 Vite 开发端口
# PUBLIC_SERVER_BASE_URL：服务端对外基础地址，供生成链接或文档展示使用
# VITE_WEB_API_BASE_URL：用户端请求 API 的基础地址
# VITE_ADMIN_API_BASE_URL：管理端请求 API 的基础地址
# -----------------------------------------------------------------------------
SERVER_PORT=17382
WEB_DEV_PORT=17380
ADMIN_DEV_PORT=17381
PUBLIC_SERVER_BASE_URL=http://localhost:17382
VITE_WEB_API_BASE_URL=http://localhost:17382
VITE_ADMIN_API_BASE_URL=http://localhost:17382
# CORS_ORIGIN：API 允许的浏览器 Origin（与地址栏一致，含协议/主机/端口）。
# 当 WEB_DEV_HOST=0.0.0.0 并用 http://<局域网IP>:WEB_DEV_PORT 打开前端时，须把该 Origin 列入，否则浏览器会报 CORS；也可在仅本地开发时设为 all（按请求回显 Origin）。
# CORS_ORIGIN=http://localhost:17380,http://127.0.0.1:17380,http://192.168.1.10:17380
# CORS_ORIGIN=all

# -----------------------------------------------------------------------------
# OpenAPI 文档控制
# true：开启 /docs 与 /openapi.json
# false：关闭文档路由
# 未配置时：非生产环境默认开启，生产环境默认关闭
# 生产环境建议显式设置为 false
# -----------------------------------------------------------------------------
# OPENAPI_ENABLED=true

# -----------------------------------------------------------------------------
# 日志配置（apps/server）
# LOG_MODE：
# - auto：开发环境输出控制台，生产环境写入文件（默认）
# - console：仅控制台
# - file：仅文件
# - both：控制台 + 文件
# LOG_DIR：日志目录，默认 logs（相对项目根目录）
# LOG_LEVEL：DEBUG | INFO | WARN | ERROR
# LOG_HTTP_ENABLED：是否记录请求日志，默认 true（test 环境固定关闭）
# API_METRICS_ENABLED：是否输出 Feed/机型列表/排行榜列表的基线性能日志（含响应字节与文件查询次数）
# LOG_MAX_READ_LINES：admin 日志 API 单次最多读取行数上限
# 持久化策略：生产环境默认以文件日志作为主存储，建议把 LOG_DIR 挂载到持久卷；
# 不建议把原始运行日志直接写入业务数据库，也不建议把对象存储作为实时日志主存。
# -----------------------------------------------------------------------------
LOG_MODE=auto
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_HTTP_ENABLED=true
API_METRICS_ENABLED=false
LOG_MAX_READ_LINES=200

# -----------------------------------------------------------------------------
# 上传大小限制，单位为 MB
# UPLOAD_MAX_FILE_SIZE_MB：所有上传统一上限
# UPLOAD_MAX_IMAGE_SIZE_MB：图片上传上限
# UPLOAD_MAX_VIDEO_SIZE_MB：视频上传上限
# 实际生效值取业务默认值与环境变量中的最小值
# 不配置时使用服务端内置默认值
# -----------------------------------------------------------------------------
# UPLOAD_MAX_FILE_SIZE_MB=20
# UPLOAD_MAX_IMAGE_SIZE_MB=10
# UPLOAD_MAX_VIDEO_SIZE_MB=50
#
# 按业务类型覆盖：
# UPLOAD_MAX_AVATAR_IMAGE_SIZE_MB=2
# UPLOAD_MAX_POST_IMAGE_SIZE_MB=10
# UPLOAD_MAX_POST_VIDEO_SIZE_MB=50
# UPLOAD_MAX_AIRCRAFT_COVER_IMAGE_SIZE_MB=10
# UPLOAD_MAX_AIRCRAFT_VIDEO_SIZE_MB=100
# UPLOAD_MAX_RANKING_COVER_IMAGE_SIZE_MB=10
# UPLOAD_MAX_RANKING_ITEM_IMAGE_SIZE_MB=10
# UPLOAD_MAX_REPORT_IMAGE_SIZE_MB=5

# -----------------------------------------------------------------------------
# 可选通用覆盖项
# WEB_DEV_HOST / ADMIN_DEV_HOST：前端开发服务器监听地址
# NODE_ENV：建议生产环境使用 production
# （CORS_ORIGIN 说明与示例见上方「服务端与前端端口」小节）
# -----------------------------------------------------------------------------
# WEB_DEV_HOST=127.0.0.1
# ADMIN_DEV_HOST=127.0.0.1
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Redis 缓存
# CACHE_PROVIDER：当前仅使用 redis
# CACHE_KEY_PREFIX：缓存前缀，便于区分环境
# CACHE_DEFAULT_TTL_SECONDS：默认缓存过期秒数
# REDIS_URL：默认对齐 docker/redis 中的 Redis 配置
# -----------------------------------------------------------------------------
CACHE_PROVIDER=redis
CACHE_KEY_PREFIX=feijia
CACHE_DEFAULT_TTL_SECONDS=300
REDIS_URL=redis://:F3j%21a_D3v_2026%23rd@localhost:6379/0

# -----------------------------------------------------------------------------
# 认证相关
# AUTH_CAPTCHA_TTL_SECONDS：图形验证码有效期
# AUTH_SMS_CODE_TTL_SECONDS：短信验证码有效期
# AUTH_SMS_CODE_LENGTH：短信验证码位数
# AUTH_CODE_HASH_SECRET：验证码哈希 pepper；生产必填，建议使用 32 字节以上随机值
# -----------------------------------------------------------------------------
AUTH_CAPTCHA_TTL_SECONDS=300
AUTH_SMS_CODE_TTL_SECONDS=300
AUTH_SMS_CODE_LENGTH=6
# AUTH_CODE_HASH_SECRET=

# -----------------------------------------------------------------------------
# 对象存储
# 环境策略：
#   development → 默认 MinIO（localhost:9000），无需额外配置
#   test / production → 必须显式设置 STORAGE_PROVIDER=kodo 及全部凭证
# STORAGE_PROVIDER：存储提供商
# - minio：仅用于本地开发
# - kodo (qiniu)：用于测试 / 生产，对接七牛云 Kodo
# STORAGE_BUCKET：桶名
# STORAGE_KEY_PREFIX：业务对象统一前缀
# STORAGE_MEMORY_ROUTE_PREFIX：内存文件路由前缀
# STORAGE_ENDPOINT：对象存储访问地址（Kodo 上传域名）
# STORAGE_REGION：区域（Kodo 用 cn-east-1）
# STORAGE_ACCESS_KEY_ID / STORAGE_SECRET_ACCESS_KEY：访问凭证
# STORAGE_FORCE_PATH_STYLE：MinIO 本地开发 true；Kodo false
# STORAGE_PUBLIC_BASE_URL：下载/CDN 域名；留空则按 endpoint 推导（Kodo 必填）
# STORAGE_AUTO_CREATE_BUCKET：本地开发 true；Kodo false
# STORAGE_PRESIGN_READ_URLS：显式控制读取 URL 是否使用预签名 GET；Kodo 默认启用签名读取，确认下载域名已公开时可设为 false。
# KODO_REGION_ID：七牛区域 ID（z0=华东，z1=华北，z2=华南）
# 媒体 URL 说明：Kodo 会默认生成私有下载 URL，避免下载域名未公开时浏览器 401。
# -----------------------------------------------------------------------------
# 本地开发（MinIO）
STORAGE_PROVIDER=minio
STORAGE_BUCKET=feijia-media
STORAGE_KEY_PREFIX=uploads
STORAGE_MEMORY_ROUTE_PREFIX=__storage
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin123
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/feijia-media
STORAGE_AUTO_CREATE_BUCKET=true
# STORAGE_PRESIGN_READ_URLS=
# -----------------------------------------------------------------------------
# 七牛云 Kodo（测试/生产 — 取消注释并填写实际值）
# STORAGE_PROVIDER=kodo
# STORAGE_ENDPOINT=https://up-z0.qiniup.com
# STORAGE_REGION=cn-east-1
# KODO_REGION_ID=z0
# STORAGE_BUCKET=your-kodo-bucket
# STORAGE_ACCESS_KEY_ID=your-ak
# STORAGE_SECRET_ACCESS_KEY=your-sk
# STORAGE_FORCE_PATH_STYLE=false
# STORAGE_AUTO_CREATE_BUCKET=false
# STORAGE_PUBLIC_BASE_URL=https://telkuj4lw.hn-bkt.clouddn.com
# -----------------------------------------------------------------------------
# TEST_STORAGE_*：测试环境存储覆盖（可选，优先级低于 STORAGE_*）
# 如果测试环境使用独立的七牛 bucket/域名，可在此设置：
# TEST_STORAGE_PROVIDER=kodo
# TEST_STORAGE_ENDPOINT=https://up-z0.qiniup.com
# TEST_STORAGE_BUCKET=your-test-bucket
# TEST_STORAGE_ACCESS_KEY_ID=your-test-ak
# TEST_STORAGE_SECRET_ACCESS_KEY=your-test-sk
# TEST_STORAGE_REGION=cn-east-1
# TEST_STORAGE_FORCE_PATH_STYLE=false
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 七牛审核（默认复用 STORAGE_ACCESS_KEY_ID / STORAGE_SECRET_ACCESS_KEY）
# QINIU_AUDIT_ACCESS_KEY_ID / QINIU_AUDIT_SECRET_ACCESS_KEY：如需与对象存储凭证分离，可单独配置
# QINIU_TEXT_AUDIT_URL：文本审核接口，默认 https://ai.qiniuapi.com/v3/text/censor
# QINIU_IMAGE_AUDIT_URL：图片审核接口，默认 https://ai.qiniuapi.com/v3/image/censor
# QINIU_VIDEO_AUDIT_URL：视频审核接口，默认 https://ai.qiniuapi.com/v3/video/censor
# QINIU_AUDIT_TEST_SUGGESTION：仅测试环境使用，可选 pass / review / block
# 注意：视频审核回调依赖 PUBLIC_SERVER_BASE_URL 为公网可访问地址，本地联调通常需要 tunnel
# -----------------------------------------------------------------------------
# QINIU_AUDIT_ACCESS_KEY_ID=
# QINIU_AUDIT_SECRET_ACCESS_KEY=
# QINIU_TEXT_AUDIT_URL=https://ai.qiniuapi.com/v3/text/censor
# QINIU_IMAGE_AUDIT_URL=https://ai.qiniuapi.com/v3/image/censor
# QINIU_VIDEO_AUDIT_URL=https://ai.qiniuapi.com/v3/video/censor
# QINIU_AUDIT_TEST_SUGGESTION=review

# -----------------------------------------------------------------------------
# 短信服务
# SMS_PROVIDER：
# - mock：本地联调推荐
# - aliyun：阿里云短信
# - tencent：腾讯云短信
# SMS_EXPOSE_MOCK_CODE：mock 模式下是否在响应中暴露验证码；仅非生产生效，生产禁止 mock provider
# -----------------------------------------------------------------------------
SMS_PROVIDER=mock
SMS_EXPOSE_MOCK_CODE=true

# -----------------------------------------------------------------------------
# 阿里云短信
# 当 SMS_PROVIDER=aliyun 时填写
# Node.js SDK 由服务端直接调用官方接口，模板变量默认按 {"code": "..."} 发送
# -----------------------------------------------------------------------------
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# -----------------------------------------------------------------------------
# 腾讯云短信
# 当 SMS_PROVIDER=tencent 时填写
# 模板参数默认按 [code] 顺序发送；PhoneNumberSet 会自动按中国大陆号码拼成 +86xxxxxxxxxxx
# -----------------------------------------------------------------------------
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
