# =============================================================================
# 怎么用：整份复制到仓库根目录，改名为 .env 再改下面的值（.env 不要提交 git）
# =============================================================================

DATABASE_URL=postgres://user:qwertyuiop@localhost:5432/feijia

# --- 开发环境端口：后端（API）与前端（Vite dev）分开配 ---
SERVER_PORT=3002
WEB_DEV_PORT=3000
ADMIN_DEV_PORT=3001
# 浏览器里请求的 API 根地址（web/admin 分开配置；本地请与 SERVER_PORT 对上）
VITE_WEB_API_BASE_URL=http://localhost:3002
VITE_ADMIN_API_BASE_URL=http://localhost:3002

# --- 需要时再解开注释 ---
# WEB_DEV_HOST=127.0.0.1
# ADMIN_DEV_HOST=127.0.0.1
# NODE_ENV=production
# CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# 少量备忘
# -----------------------------------------------------------------------------
# · 后端端口只认 SERVER_PORT；云上若平台强制注入 PORT、且你没设 SERVER_PORT，才会用 PORT。
# · WEB_DEV_* 只作用于 apps/web 的 vite dev；ADMIN_DEV_* 只作用于 apps/admin。
# · NODE_ENV=production：后端日志写入 apps/server/logs/。
# · 前端打包上线：根目录建 .env.production，分别设置 VITE_WEB_API_BASE_URL 与 VITE_ADMIN_API_BASE_URL。

# -----------------------------------------------------------------------------
# Runtime providers (storage / cache / sms)
# -----------------------------------------------------------------------------
# storage provider: minio | cos | oss | kodo
STORAGE_PROVIDER=minio
STORAGE_BUCKET=feijia-media
STORAGE_KEY_PREFIX=uploads
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin123
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=
STORAGE_AUTO_CREATE_BUCKET=true

# cache provider: redis
CACHE_PROVIDER=redis
REDIS_URL=redis://:qwertyuiop@localhost:6379/0

# sms provider: mock | aliyun | tencent
SMS_PROVIDER=mock
SMS_EXPOSE_MOCK_CODE=true

# aliyun sms (when SMS_PROVIDER=aliyun)
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# tencent sms (when SMS_PROVIDER=tencent)
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
