# =============================================================================
# 飞加环境变量模板
# 用法：
# 1. 复制为根目录 `.env`
# 2. 本地开发可直接使用默认值
# 3. 生产部署请替换数据库、Redis、对象存储与短信服务的真实配置
# 4. 如果 URL 中密码包含 `#`、`!`、`@` 等特殊字符，请做 URL 编码
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库
# 数据库连接串，默认对齐 docker/database 中的 PostgreSQL 配置
# 本地默认库名：feijia
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://feijia_dev:F3j%21a_D3v_2026%23pg@localhost:5432/feijia

# -----------------------------------------------------------------------------
# 服务端与前端端口
# SERVER_PORT：后端 API 监听端口
# WEB_DEV_PORT：用户端 Vite 开发端口
# ADMIN_DEV_PORT：管理端 Vite 开发端口
# PUBLIC_SERVER_BASE_URL：服务端对外基础地址，供生成链接或文档展示使用
# VITE_WEB_API_BASE_URL：用户端请求 API 的基础地址
# VITE_ADMIN_API_BASE_URL：管理端请求 API 的基础地址
# -----------------------------------------------------------------------------
SERVER_PORT=3002
WEB_DEV_PORT=3000
ADMIN_DEV_PORT=3001
PUBLIC_SERVER_BASE_URL=http://localhost:3002
VITE_WEB_API_BASE_URL=http://localhost:3002
VITE_ADMIN_API_BASE_URL=http://localhost:3002
# CORS_ORIGIN：API 允许的浏览器 Origin（与地址栏一致，含协议/主机/端口）。
# 当 WEB_DEV_HOST=0.0.0.0 并用 http://<局域网IP>:WEB_DEV_PORT 打开前端时，须把该 Origin 列入，否则浏览器会报 CORS；也可在仅本地开发时设为 all（按请求回显 Origin）。
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.10:3000
# CORS_ORIGIN=all

# -----------------------------------------------------------------------------
# OpenAPI 文档控制
# true：开启 /docs 与 /openapi.json
# false：关闭文档路由
# 未配置时：非生产环境默认开启，生产环境默认关闭
# 生产环境建议显式设置为 false
# -----------------------------------------------------------------------------
OPENAPI_ENABLED=true

# -----------------------------------------------------------------------------
# 上传大小限制，单位为 MB
# UPLOAD_MAX_FILE_SIZE_MB：所有上传统一上限
# UPLOAD_MAX_IMAGE_SIZE_MB：图片上传上限
# UPLOAD_MAX_VIDEO_SIZE_MB：视频上传上限
# 实际生效值取业务默认值与环境变量中的最小值
# 不配置时使用服务端内置默认值
# -----------------------------------------------------------------------------
# UPLOAD_MAX_FILE_SIZE_MB=20
# UPLOAD_MAX_IMAGE_SIZE_MB=10
# UPLOAD_MAX_VIDEO_SIZE_MB=50
#
# 按业务类型覆盖：
# UPLOAD_MAX_AVATAR_IMAGE_SIZE_MB=2
# UPLOAD_MAX_POST_IMAGE_SIZE_MB=10
# UPLOAD_MAX_POST_VIDEO_SIZE_MB=50
# UPLOAD_MAX_AIRCRAFT_COVER_IMAGE_SIZE_MB=10
# UPLOAD_MAX_AIRCRAFT_VIDEO_SIZE_MB=100
# UPLOAD_MAX_RANKING_COVER_IMAGE_SIZE_MB=10
# UPLOAD_MAX_RANKING_ITEM_IMAGE_SIZE_MB=10
# UPLOAD_MAX_REPORT_IMAGE_SIZE_MB=5

# -----------------------------------------------------------------------------
# 可选通用覆盖项
# WEB_DEV_HOST / ADMIN_DEV_HOST：前端开发服务器监听地址
# NODE_ENV：建议生产环境使用 production
# （CORS_ORIGIN 说明与示例见上方「服务端与前端端口」小节）
# -----------------------------------------------------------------------------
# WEB_DEV_HOST=127.0.0.1
# ADMIN_DEV_HOST=127.0.0.1
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Redis 缓存
# CACHE_PROVIDER：当前仅使用 redis
# CACHE_KEY_PREFIX：缓存前缀，便于区分环境
# CACHE_DEFAULT_TTL_SECONDS：默认缓存过期秒数
# REDIS_URL：默认对齐 docker/redis 中的 Redis 配置
# -----------------------------------------------------------------------------
CACHE_PROVIDER=redis
CACHE_KEY_PREFIX=feijia
CACHE_DEFAULT_TTL_SECONDS=300
REDIS_URL=redis://:F3j%21a_D3v_2026%23rd@localhost:6379/0

# -----------------------------------------------------------------------------
# 认证相关
# AUTH_CAPTCHA_TTL_SECONDS：图形验证码有效期
# AUTH_SMS_CODE_TTL_SECONDS：短信验证码有效期
# AUTH_SMS_CODE_LENGTH：短信验证码位数
# -----------------------------------------------------------------------------
AUTH_CAPTCHA_TTL_SECONDS=300
AUTH_SMS_CODE_TTL_SECONDS=300
AUTH_SMS_CODE_LENGTH=6

# -----------------------------------------------------------------------------
# 对象存储
# STORAGE_PROVIDER：存储提供商，当前默认使用 MinIO
# STORAGE_BUCKET：桶名
# STORAGE_KEY_PREFIX：业务对象统一前缀
# STORAGE_MEMORY_ROUTE_PREFIX：内存文件路由前缀
# STORAGE_ENDPOINT：对象存储访问地址
# STORAGE_REGION：区域
# STORAGE_ACCESS_KEY_ID / STORAGE_SECRET_ACCESS_KEY：访问凭证
# STORAGE_FORCE_PATH_STYLE：MinIO 本地开发建议为 true
# STORAGE_PUBLIC_BASE_URL：如需 CDN 域名，可在这里配置；留空则按 endpoint 推导
# STORAGE_AUTO_CREATE_BUCKET：本地开发建议开启，自动创建 bucket
# STORAGE_PRESIGN_READ_URLS：设为 1/true/on 时，在 STORAGE_ENDPOINT 为 localhost/127.0.0.1 时强制对读取 URL 使用预签名 GET（即使 NODE_ENV=production，仅用于本地排查）
# 媒体 URL 说明：默认 MinIO 桶常未开放匿名读，直连（无查询参数）在浏览器易 403。
# 非 production 且 endpoint 为本机时，服务端会对头像/封面等返回预签名 URL；若坚持用直链，请在 MinIO 配置桶匿名读（如对前缀 uploads/）。
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=minio
STORAGE_BUCKET=feijia-media
STORAGE_KEY_PREFIX=uploads
STORAGE_MEMORY_ROUTE_PREFIX=__storage
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin123
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=
STORAGE_AUTO_CREATE_BUCKET=true
# STORAGE_PRESIGN_READ_URLS=

# -----------------------------------------------------------------------------
# 短信服务
# SMS_PROVIDER：
# - mock：本地联调推荐
# - aliyun：阿里云短信
# - tencent：腾讯云短信
# SMS_EXPOSE_MOCK_CODE：mock 模式下是否在响应中暴露验证码，开发环境推荐开启
# -----------------------------------------------------------------------------
SMS_PROVIDER=mock
SMS_EXPOSE_MOCK_CODE=true

# -----------------------------------------------------------------------------
# 阿里云短信
# 当 SMS_PROVIDER=aliyun 时填写
# -----------------------------------------------------------------------------
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# -----------------------------------------------------------------------------
# 腾讯云短信
# 当 SMS_PROVIDER=tencent 时填写
# -----------------------------------------------------------------------------
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
