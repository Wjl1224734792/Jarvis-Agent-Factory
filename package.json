{
  "name": "jarvis-agent-factory",
  "version": "4.7.31",
  "description": "Jarvis Agent Factory CLI — Claude Code 多智能体 AI 编程助手配置安装器 | Multi-agent AI coding assistant config installer for Claude Code",
  "keywords": [
    "jarvis",
    "agent",
    "ai",
    "claude-code",
    "multi-agent",
    "orchestration",
    "skills",
    "pipeline",
    "agenti"
  ],
  "homepage": "https://github.com/Wjl1224734792/Jarvis-Agent-Factory",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wjl1224734792/Jarvis-Agent-Factory.git"
  },
  "license": "MIT",
  "author": "lin <wujl1124@163.com>",
  "type": "module",
  "bin": {
    "jarvis": "bin/jarvis.js",
    "jaf": "bin/jarvis.js"
  },
  "files": [
    "bin/",
    "dist/",
    ".npmignore"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "clean": "node -e \"import{rmSync}from'fs';try{rmSync('dist',{recursive:true,force:true})}catch(e){}\"",
    "prebuild": "npm run clean",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc && node -e \"import{cpSync,rmSync}from'fs';cpSync('package.json','dist/package.json');cpSync('src/templates','dist/src/templates',{recursive:true});try{rmSync('dist/tests',{recursive:true,force:true})}catch(e){}\" && npm run build:web",
    "build:web": "cd web && npm run build",
    "dev": "tsx src/cli/index.ts",
    "jarvis": "node dist/src/cli/index.js",
    "version:sync": "node scripts/sync-version.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm audit --audit-level=moderate",
    "preversion": "npm run check && npm run build",
    "version": "npm run version:sync && git add QUICKSTART.md web/public/guide.html src/templates/platforms/claude/skills/concurrency-policy/SKILL.md",
    "prerelease": "npm run version:sync && npm run check && npm run build",
    "dev:setup": "node -e \"import{cpSync}from'fs';cpSync('.mcp.dev.json','.mcp.json');console.log('✓ .mcp.json configured for local development (JARVIS_DEV=1)');console.log('  Run: npm run build');console.log('  Then restart Claude Code session to pick up new MCP config');\""
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.3",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.22",
    "yaml": "^2.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  }
}
