{
  "name": "jarvis-agent-factory",
  "version": "3.25.0",
  "description": "Jarvis Agent Factory CLI — 跨平台多智能体 AI 编程助手配置安装器 | Multi-agent AI coding assistant config installer for Claude Code / OpenCode / Codex",
  "keywords": [
    "jarvis",
    "agent",
    "ai",
    "claude-code",
    "opencode",
    "codex",
    "multi-agent",
    "orchestration",
    "skills",
    "pipeline",
    "agenti"
  ],
  "homepage": "https://github.com/Wjl1224734792/Jarvis-Agent-Factory",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wjl1224734792/Jarvis-Agent-Factory.git"
  },
  "license": "MIT",
  "author": "lin <wujl1124@163.com>",
  "type": "module",
  "bin": {
    "jarvis": "bin/jarvis.js",
    "jaf": "bin/jarvis.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc && node -e \"import{cpSync}from'fs';cpSync('src/web/views','dist/src/web/views',{recursive:true})\"",
    "dev": "tsx src/cli.ts",
    "jarvis": "node dist/src/cli.js",
    "jarvis:dev": "tsx src/cli.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.17"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  }
}
