{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "jarvis-engine": {
      "type": "remote",
      "url": "http://localhost:3456/mcp",
      "enabled": true,
      "timeout": 30000
    }
  }
}
