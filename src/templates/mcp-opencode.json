{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "jarvis-engine": {
      "type": "local",
      "command": ["jarvis", "engine", "start", "--stdio"],
      "enabled": true
    }
  }
}
