{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "jarvis-engine": {
      "type": "stdio",
      "command": "jarvis",
      "args": ["engine", "start", "--stdio"]
    }
  }
}
