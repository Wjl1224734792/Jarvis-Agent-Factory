{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "disableBypassPermissionsMode": false,
  "hooks": {
    "PreToolUse": [
      { "type": "command", "command": "jarvis hook gate-check" }
    ],
    "PostToolUse": [
      { "type": "command", "command": "jarvis hook gate-check" }
    ],
    "Stop": [
      { "type": "command", "command": "jarvis hook status" }
    ],
    "SessionStart": [],
    "UserPromptSubmit": []
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(bun:*)",
      "Bash(bun run *)",
      "Bash(docker:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "WebFetch",
      "WebSearch",
      "Skill(*)",
      "mcp__chrome-devtools__*",
      "mcp__playwright__*",
      "mcp__jarvis-engine__*"
    ]
  }
}
