{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "jarvis hook gate-check"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/agent-event.sh",
            "env": {
              "HOOK_EVENT_TYPE": "start"
            }
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scripts/agent-event.sh",
            "env": {
              "HOOK_EVENT_TYPE": "stop"
            }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jarvis hook status"
          }
        ]
      }
    ]
  }
}