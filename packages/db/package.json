{
  "name": "@feijia/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "generate": "drizzle-kit generate --config drizzle.config.ts",
    "push": "drizzle-kit push --config drizzle.config.ts",
    "migrate": "bun run ./src/migrate.cli.ts",
    "seed": "bun run ./src/seed.cli.ts",
    "seed:test-data": "bun run ./src/seed.test-data.ts",
    "clear": "bun run ./src/clear.cli.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0"
  }
}
