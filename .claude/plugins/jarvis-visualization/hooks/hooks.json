{
  "hooks": [
    {
      "event": "SubagentStart",
      "type": "command",
      "command": ".claude/plugins/jarvis-visualization/hooks/scripts/agent-event.sh",
      "env": {
        "HOOK_EVENT_TYPE": "start"
      }
    },
    {
      "event": "SubagentEnd",
      "type": "command",
      "command": ".claude/plugins/jarvis-visualization/hooks/scripts/agent-event.sh",
      "env": {
        "HOOK_EVENT_TYPE": "end"
      }
    }
  ]
}
