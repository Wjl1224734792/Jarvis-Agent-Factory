{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "server",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--watch", "apps/server/src/index.ts"],
      "port": 17382,
      "autoPort": true
    },
    {
      "name": "web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--cwd", "apps/web", "dev"],
      "port": 17380,
      "autoPort": true
    },
    {
      "name": "admin",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--cwd", "apps/admin", "dev"],
      "port": 17381,
      "autoPort": true
    }
  ]
}
