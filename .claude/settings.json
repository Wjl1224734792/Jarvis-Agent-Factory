{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(bun:*)",
      "Bash(bun run *)",
      "Bash(docker:*)",
      "WebFetch",
      "WebSearch",
      "Skill(*)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(npx tsc *)",
      "mcp__Claude_Preview__preview_start",
      "Bash(echo \"EXIT:$?\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "jarvis hook gate-check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jarvis hook status"
          }
        ]
      }
    ]
  }
}